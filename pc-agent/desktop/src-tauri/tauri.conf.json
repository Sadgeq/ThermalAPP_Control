{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ThermalControl",
  "version": "3.2.0",
  "identifier": "com.thermalcontrol.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ThermalControl",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
"csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8420 ws://127.0.0.1:8420 https://gwpqkvsvhobkkqctjduc.supabase.co https://*.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:"    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}